# ── Required: the AI brain ──────────────────────────────────────────────
# Get a key at https://platform.claude.com
ANTHROPIC_API_KEY=sk-ant-...

# ── Store niche (optional — leave blank and the AI picks one) ───────────
OMNISTORE_NICHE=

# ── Model (optional) ─────────────────────────────────────────────────────
# Default claude-opus-4-8 = smartest. Cheapest runs: claude-haiku-4-5
OMNISTORE_MODEL=

# ── Shopify (store + listings) ──────────────────────────────────────────
# Create a custom app in Shopify admin → Settings → Apps → Develop apps,
# grant write_products scope, and copy the Admin API access token.
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_...

# ── Meta (Facebook Page + Instagram posting) ────────────────────────────
# Page access token with pages_manage_posts; IG business account linked to the page.
META_PAGE_ID=
META_PAGE_ACCESS_TOKEN=
META_IG_USER_ID=

# ── X / Twitter (posting) ────────────────────────────────────────────────
# OAuth 2.0 user access token with tweet.write scope.
X_ACCESS_TOKEN=

# ── TikTok (video posting via official Content Posting API) ─────────────
# 1. Create an app at https://developers.tiktok.com (free)
# 2. Add the Content Posting API product, request video.publish scope
# 3. Connect YOUR TikTok account via the app's OAuth flow → access token below
# NEVER put your TikTok username/password anywhere — it isn't needed.
TIKTOK_ACCESS_TOKEN=
# SELF_ONLY = posts visible only to you in-app (required until TikTok audits
# your app; also a nice final safety check). After audit: PUBLIC_TO_EVERYONE
TIKTOK_PRIVACY_LEVEL=SELF_ONLY
# true = rendered videos post automatically 3x/day on autopilot, no approval
# step. false = every video waits in your queue until you approve it.
OMNISTORE_TIKTOK_AUTOPOST=false

# ── Behavior ─────────────────────────────────────────────────────────────
# true  = generate everything but do NOT publish anywhere (safe default)
# false = actually create Shopify products and publish social posts
OMNISTORE_DRY_RUN=true

# How many new products to hunt per research cycle
OMNISTORE_PRODUCTS_PER_CYCLE=3

# Default retail markup applied to estimated supplier cost (2.5 = 150% margin)
OMNISTORE_MARKUP=2.5
