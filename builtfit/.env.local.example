# ---------------------------------------------------------------------------
# BuiltFit environment — copy to .env.local and fill in.
# ---------------------------------------------------------------------------

# Supabase (required) — from your project's Settings → API page.
# The URL of your Supabase project.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
# The anon/public key. Safe to expose to the browser; RLS protects data.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service-role key (server-only; NEVER expose to the browser).
# Used for: writing API results into the shared foods_cache, and real
# account deletion. The app runs without it, minus those two features.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# USDA FoodData Central (recommended) — free key from
# https://fdc.nal.usda.gov/api-key-signup.html
# Falls back to DEMO_KEY (heavily rate-limited) if unset.
USDA_API_KEY=

# Open Food Facts needs no key.

# ---------------------------------------------------------------------------
# Stripe (scaffold only — leave disabled at launch).
# Core tracking is free forever; subscriptions would only ever gate
# non-core extras (see lib/flags.ts).
# ---------------------------------------------------------------------------
# Master switch for any pricing UI / checkout. Keep false.
NEXT_PUBLIC_SUBSCRIPTIONS_ENABLED=false
# Secret API key (sk_...). Only needed if subscriptions are ever enabled.
STRIPE_SECRET_KEY=
# Webhook signing secret (whsec_...) for /api/stripe/webhook.
STRIPE_WEBHOOK_SECRET=
# Price id for the future BuiltFit+ plan (price_...).
STRIPE_PLUS_PRICE_ID=
